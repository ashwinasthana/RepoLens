{
  "manifest_version": 3,
  "name": "RepoLens",
  "version": "1.0.0",
  "description": "AI-powered GitHub repository analyzer",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "permissions": ["storage", "scripting"],
  "host_permissions": [
    "https://github.com/*",
    "https://api.github.com/*",
    "https://api.groq.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://github.com/*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["sidebar.html", "sidebar.js", "services.js", "sidebar.css"],
      "matches": ["https://github.com/*"]
    }
  ],
  "action": {
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    },
    "default_title": "RepoLens"
  }
}
